<h1><%= @kitten.name %></h1>

<p><strong>Age:</strong> <%= @kitten.age %></p>
<p><strong>Cuteness:</strong> <%= @kitten.cuteness %></p>
<p><strong>Softness:</strong> <%= @kitten.softness %></p>

<%= link_to '✏️ Edit details', edit_kitten_path(@kitten) %>
<%= link_to '📋 Back to all kittens', kittens_path %>
<%= button_to '🗑️ Delete kitten', kitten_path(@kitten),
              data: { turbo_method: :delete, turbo_confirm: 'Are you sure you want to delete the cuteness?' } %>



